# Student Help App — Environment Variables

# Database (Neon PostgreSQL)
# Get from https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/student_help?sslmode=require"

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-change-in-production"
AUTH_URL="https://your-app.vercel.app"

# Google OAuth
# Get from https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Uploadthing (file uploads — optional for MVP)
# Get from https://uploadthing.com
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# LiveKit Cloud (video sessions)
# Get from https://cloud.livekit.io
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL="wss://your-project.livekit.cloud"

# Payments (Razorpay — mock mode for MVP)
# Get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# OpenAI (GPT-4o — AI doubt solver, practice, summaries)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Resend (Email — optional for MVP)
# Get from https://resend.com
RESEND_API_KEY=""

# Bot teacher (dev only — set to true to simulate teacher auto-join after 60s)
# When disabled/false, all bot-teacher code paths are inert
NEXT_PUBLIC_ENABLE_BOT_TEACHER=false

# Dev seed (dummy teachers/data for testing)
# Set this and visit /api/dev/seed?key=<value> to populate dummy data
SEED_SECRET=""
