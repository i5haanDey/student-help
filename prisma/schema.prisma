generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  student
  teacher
  admin
}

enum AuthProvider {
  email
  google
}

enum VerificationStatus {
  pending
  under_review
  approved
  rejected
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
  disputed
}

enum SessionType {
  instant
  scheduled
}

enum ConfidenceLevel {
  high
  medium
  low
}

enum ExplainMode {
  standard
  simple
  visual
  analogy
  step_by_step
  exam_oriented
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @map("refresh_token")
  access_token      String? @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token")
  session_state     String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  role          Role      @default(student)
  passwordHash  String?   @map("password_hash")
  authProvider  AuthProvider @default(email) @map("auth_provider")
  isVerified    Boolean   @default(false) @map("is_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @default(now()) @map("updated_at")
  lastActiveAt  DateTime? @map("last_active_at")
  isDeleted     Boolean   @default(false) @map("is_deleted")

  accounts Account[]
  sessions Session[]
  profile  Profile?

  @@map("users")
}

model Profile {
  id                String              @id @default(cuid())
  userId            String              @unique @map("user_id")
  displayName       String              @map("display_name")
  avatarUrl         String?             @map("avatar_url")
  role              Role

  gradeLevel        String?             @map("grade_level")
  examTargets       String[]            @map("exam_targets")
  preferredLanguages String[]           @map("preferred_languages")
  timezone          String              @default("Asia/Kolkata")

  bio               String?
  subjects          String[]
  teachingLanguages String[]            @map("teaching_languages")
  hourlyRateInr     Decimal?            @db.Decimal(8, 2) @map("hourly_rate_inr")
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  verificationDocs  Json?               @map("verification_docs")
  isAvailableNow    Boolean             @default(false) @map("is_available_now")
  compositeScore    Decimal?            @default(0) @db.Decimal(5, 2) @map("composite_score")
  totalSessions     Int                 @default(0) @map("total_sessions")
  rank              String              @default("verified")
  reliabilityScore  Int?                @default(100) @map("reliability_score")
  earningsTotal     Decimal?            @default(0) @db.Decimal(12, 2) @map("earnings_total")
  earningsPending   Decimal?            @default(0) @db.Decimal(12, 2) @map("earnings_pending")
  updatedAt         DateTime            @updatedAt @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  availabilitySlots  TeacherAvailabilitySlot[]
  bookingsAsStudent  Booking[]                @relation("StudentBookings")
  bookingsAsTeacher  Booking[]                @relation("TeacherBookings")
  ratingsGiven       Rating[]                 @relation("StudentRatings")
  ratingsReceived    Rating[]                 @relation("TeacherRatings")
  chatMessages       SessionChatMessage[]
  doubtSubmissions   AiDoubtSubmission[]
  practiceSets       PracticeSet[]
  masteryScores      MasteryScore[]
  notifications      Notification[]

  @@map("profiles")
}

model TeacherAvailabilitySlot {
  id         String   @id @default(cuid())
  teacherId  String   @map("teacher_id")
  slotStart  DateTime @map("slot_start")
  slotEnd    DateTime @map("slot_end")
  isRecurring Boolean @default(false) @map("is_recurring")
  isBooked   Boolean  @default(false) @map("is_booked")

  teacher Profile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_availability_slots")
}

model Booking {
  id              String       @id @default(cuid())
  studentId       String       @map("student_id")
  teacherId       String       @map("teacher_id")
  subject         String
  doubtContext    String?      @map("doubt_context")
  sessionType     SessionType  @map("session_type")
  durationMinutes Int          @map("duration_minutes")
  status          BookingStatus @default(pending)
  amountInr       Decimal?     @db.Decimal(8, 2) @map("amount_inr")
  platformFeeInr  Decimal?     @db.Decimal(8, 2) @map("platform_fee_inr")
  teacherPayoutInr Decimal?    @db.Decimal(8, 2) @map("teacher_payout_inr")
  paymentId       String?      @map("payment_id")
  roomUrl         String?      @map("room_url")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @default(now()) @map("updated_at")
  startsAt        DateTime?    @map("starts_at")
  endedAt         DateTime?    @map("ended_at")

  student Profile @relation("StudentBookings", fields: [studentId], references: [id])
  teacher Profile @relation("TeacherBookings", fields: [teacherId], references: [id])
  liveSession LiveSession?

  @@index([studentId, status])
  @@index([teacherId, status])
  @@map("bookings")
}

model LiveSession {
  id              String      @id @default(cuid())
  bookingId       String      @unique @map("booking_id")
  roomName        String?     @map("room_name")
  recordingUrl    String?     @map("recording_url")
  transcriptText  String?     @map("transcript_text")
  summaryText     String?     @map("summary_text")
  whiteboardState Json?       @default("{}") @map("whiteboard_state")
  startedAt       DateTime?   @map("started_at")
  endedAt         DateTime?   @map("ended_at")
  aiSummaryStatus String      @default("pending") @map("ai_summary_status")
  updatedAt       DateTime    @updatedAt @default(now()) @map("updated_at")

  teacherJoinedAt   DateTime? @map("teacher_joined_at")
  studentJoinedAt   DateTime? @map("student_joined_at")
  actualStartAt     DateTime? @map("actual_start_at")
  extendedByMinutes Int?      @default(0) @map("extended_by_minutes")
  graceEndedAt      DateTime? @map("grace_ended_at")
  teacherDurationMs Int?      @default(0) @map("teacher_duration_ms")
  studentDurationMs Int?      @default(0) @map("student_duration_ms")
  admittedAt        DateTime? @map("admitted_at")
  disconnectedAt    DateTime? @map("disconnected_at")

  extensionRequestedBy String? @map("extension_requested_by")
  extensionRequestedMin Int?   @default(0) @map("extension_requested_min")
  extensionStatus     String?  @default("none") @map("extension_status")
  extensionExpiresAt  DateTime? @map("extension_expires_at")

  booking      Booking              @relation(fields: [bookingId], references: [id])
  chatMessages SessionChatMessage[]
  practiceSets PracticeSet[]
  ratings      Rating[]

  @@map("live_sessions")
}

model SessionChatMessage {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  senderId    String   @map("sender_id")
  messageText String   @map("message_text")
  messageType String   @default("text") @map("message_type")
  createdAt   DateTime @default(now()) @map("created_at")

  liveSession LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender       Profile    @relation(fields: [senderId], references: [id])

  @@index([sessionId])
  @@map("session_chat_messages")
}

model AiDoubtSubmission {
  id              String         @id @default(cuid())
  studentId       String         @map("student_id")
  bookingId       String?        @map("booking_id")
  inputType       String         @map("input_type")
  inputText       String?        @map("input_text")
  inputFileUrl    String?        @map("input_file_url")
  subjectDetected String?        @map("subject_detected")
  confidenceLevel ConfidenceLevel? @map("confidence_level")
  aiResponseText  String?        @map("ai_response_text")
  explainMode     ExplainMode    @default(standard) @map("explain_mode")
  isAsync         Boolean        @default(false) @map("is_async")
  asyncResolvedAt DateTime?      @map("async_resolved_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  student Profile @relation(fields: [studentId], references: [id])

  @@index([studentId, createdAt])
  @@map("ai_doubt_submissions")
}

model PracticeSet {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  studentId   String   @map("student_id")
  subject     String
  conceptTags String[] @map("concept_tags")
  questions   Json
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  liveSession LiveSession @relation(fields: [sessionId], references: [id])
  student     Profile     @relation(fields: [studentId], references: [id])
  attempts PracticeAttempt[]

  @@map("practice_sets")
}

model PracticeAttempt {
  id            String   @id @default(cuid())
  practiceSetId String   @map("practice_set_id")
  questionId    String   @map("question_id")
  studentAnswer String?  @map("student_answer")
  isCorrect     Boolean? @map("is_correct")
  createdAt     DateTime @default(now()) @map("created_at")

  practiceSet PracticeSet @relation(fields: [practiceSetId], references: [id], onDelete: Cascade)

  @@map("practice_attempts")
}

model MasteryScore {
  id           String   @id @default(cuid())
  studentId    String   @map("student_id")
  subject      String
  score        Decimal  @default(0) @db.Decimal(5, 2)
  sessionCount Int      @default(0) @map("session_count")
  practiceCount Int     @default(0) @map("practice_count")
  lastUpdated  DateTime @default(now()) @map("last_updated")

  student Profile @relation(fields: [studentId], references: [id])

  @@unique([studentId, subject])
  @@map("mastery_scores")
}

model Rating {
  id        String   @id @default(cuid())
  sessionId String   @unique @map("session_id")
  studentId String   @map("student_id")
  teacherId String   @map("teacher_id")
  stars     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  liveSession LiveSession @relation(fields: [sessionId], references: [id])
  student     Profile     @relation("StudentRatings", fields: [studentId], references: [id])
  teacher     Profile     @relation("TeacherRatings", fields: [teacherId], references: [id])

  @@map("ratings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  body      String?
  type      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
